{
  "name": "@eduardocecon/cappy",
  "version": "0.1.0",
  "description": "Cappy AI agent — terminal CLI",
  "license": "MIT",
  "type": "module",
  "files": [
    "dist/index.js"
  ],
  "bin": {
    "cappy": "./dist/index.js"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js --external:vscode --banner:js=\"#!/usr/bin/env node\"",
    "dev": "node --import tsx/esm src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.105.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.4",
    "typescript": "^6.0.2"
  }
}
