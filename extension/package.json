{
  "name": "cappy",
  "version": "3.2.17",
  "displayName": "Cappy",
  "description": "Your autonomous AI dev companion — VS Code shell for the cappy CLI",
  "publisher": "eduardocecon",
  "icon": "media/icon.png",
  "homepage": "https://github.com/eduardocecon/cappy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduardocecon/cappy"
  },
  "bugs": {
    "url": "https://github.com/eduardocecon/cappy/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "openrouter"
  ],
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cappy-sidebar",
          "title": "Cappy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cappy-sidebar": [
        {
          "type": "tree",
          "id": "cappy.sessions",
          "name": "Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "cappy.newSession",
        "title": "Cappy: New Session",
        "icon": "$(add)"
      },
      {
        "command": "cappy.resumeSession",
        "title": "Cappy: Resume Session"
      },
      {
        "command": "cappy.openSessions",
        "title": "Cappy: Show Sessions",
        "icon": "$(folder-opened)"
      },
      {
        "command": "cappy.deleteSession",
        "title": "Cappy: Delete Session…",
        "icon": "$(trash)"
      },
      {
        "command": "cappy.refreshSessions",
        "title": "Cappy: Refresh Sessions",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cappy.newSession",
          "when": "view == cappy.sessions",
          "group": "navigation@1"
        },
        {
          "command": "cappy.refreshSessions",
          "when": "view == cappy.sessions",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "cappy.deleteSession",
          "when": "view == cappy.sessions && viewItem == cappy.session",
          "group": "modify"
        }
      ]
    },
    "configuration": {
      "title": "Cappy",
      "properties": {
        "cappy.cli.command": {
          "type": "string",
          "default": "cappy",
          "description": "Shell command run in the integrated terminal to launch the Cappy CLI. Override if cappy is not on PATH (e.g. \"npx -y @eduardocecon/cappy\")."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "pnpm run build:ext",
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=out/extension.js",
    "watch": "tsc -watch -p tsconfig.json --outDir out",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "~1.105.0",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  }
}
