{
  "name": "cappy",
  "version": "3.2.17",
  "displayName": "Cappy",
  "description": "Your autonomous AI dev companion",
  "publisher": "eduardocecon",
  "icon": "media/icon.png",
  "homepage": "https://github.com/eduardocecon/cappy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduardocecon/cappy"
  },
  "bugs": {
    "url": "https://github.com/eduardocecon/cappy/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "mcp",
    "openrouter",
    "copilot"
  ],
  "qna": "https://github.com/github-community/community/discussions/categories/copilot",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cappy-sidebar",
          "title": "Cappy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cappy-sidebar": [
        {
          "type": "tree",
          "id": "cappy.sessions",
          "name": "Sessions"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "cappy.session",
        "displayName": "Cappy Session",
        "selector": [
          {
            "filenamePattern": "*.cappy"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "cappy.newSession",
        "title": "Cappy: New Session",
        "icon": "$(add)"
      },
      {
        "command": "cappy.openSessions",
        "title": "Cappy: Open Session…",
        "icon": "$(folder-opened)"
      },
      {
        "command": "cappy.deleteSession",
        "title": "Cappy: Delete Session…",
        "icon": "$(trash)"
      },
      {
        "command": "cappy.refreshSessions",
        "title": "Cappy: Refresh Sessions",
        "icon": "$(refresh)"
      },
      {
        "command": "cappy.showLog",
        "title": "Cappy: Show Output Log"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "cappy.newSession",
          "when": "view == cappy.sessions",
          "group": "navigation@1"
        },
        {
          "command": "cappy.refreshSessions",
          "when": "view == cappy.sessions",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "cappy.deleteSession",
          "when": "view == cappy.sessions && viewItem == cappy.session",
          "group": "modify"
        }
      ]
    },
    "configuration": {
      "title": "Cappy",
      "properties": {}
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "pnpm run build:webview && pnpm run build:ext",
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=out/extension.js",
    "build:webview": "cd ../webview && pnpm run build && cd ..",
    "watch": "tsc -watch -p tsconfig.json --outDir out",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^8.0.4",
    "node-pty": "^1.1.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.2",
    "@types/vscode": "~1.105.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
