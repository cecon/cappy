{
  "name": "cappy",
  "version": "3.2.17",
  "displayName": "Cappy",
  "description": "Your autonomous AI dev companion",
  "publisher": "eduardocecon",
  "icon": "media/icon.png",
  "homepage": "https://github.com/eduardocecon/cappy#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eduardocecon/cappy"
  },
  "bugs": {
    "url": "https://github.com/eduardocecon/cappy/issues"
  },
  "keywords": [
    "ai",
    "agent",
    "coding",
    "mcp",
    "openrouter",
    "copilot"
  ],
  "qna": "https://github.com/github-community/community/discussions/categories/copilot",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cappy-sidebar",
          "title": "Cappy",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "cappy-sidebar": [
        {
          "type": "webview",
          "id": "cappy.chatView",
          "name": "Cappy"
        }
      ]
    },
    "commands": [
      {
        "command": "cappy.openChat",
        "title": "Cappy: Open Chat"
      },
      {
        "command": "cappy.clearChat",
        "title": "Cappy: Clear Chat"
      },
      {
        "command": "cappy.launchOpenClaude",
        "title": "Cappy: Launch OpenClaude CLI"
      },
      {
        "command": "cappy.launchOpenClaudeWorkspaceRoot",
        "title": "Cappy: Launch OpenClaude CLI (workspace root)"
      },
      {
        "command": "cappy.openOpenClaudeProfile",
        "title": "Cappy: Open OpenClaude workspace profile"
      },
      {
        "command": "cappy.openOpenClaudeRepository",
        "title": "Cappy: Open OpenClaude repository"
      },
      {
        "command": "cappy.showLog",
        "title": "Cappy: Show Output Log"
      }
    ],
    "configuration": {
      "title": "Cappy",
      "properties": {
        "cappy.openClaudeCli.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable commands that launch the OpenClaude CLI in an integrated terminal."
        },
        "cappy.openClaudeCli.command": {
          "type": "string",
          "default": "npx -y @gitlawb/openclaude",
          "description": "Shell command run in the terminal (same idea as the OpenClaude VS Code extension)."
        },
        "cappy.openClaudeCli.terminalName": {
          "type": "string",
          "default": "OpenClaude",
          "description": "Integrated terminal tab title for OpenClaude CLI sessions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "pnpm run build:webview && pnpm run build:ext",
    "build:ext": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=out/extension.js",
    "build:webview": "cd ../webview && pnpm run build && cd ..",
    "watch": "tsc -watch -p tsconfig.json --outDir out",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "diff": "^8.0.4",
    "node-pty": "^1.1.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^25.5.2",
    "@types/vscode": "~1.105.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vscode/vsce": "3.7.1",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^2.1.9"
  }
}
