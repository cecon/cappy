# Exclude source and dev files from the VSIX package

# Workspace data
.cappy/
.cappy/**

# Dev folders
.vscode/
.git/
.gitignore
.github/
old/

# Source code (compiled output is in out/)
src/**
!src/assets/**

# Config files
tsconfig*.json
tsconfig*.tsbuildinfo
eslint.config.js
.eslintignore
.eslintrc*
.prettierrc*
*.log
.env
.env.local

# Scripts (build/publish helpers excluded)
scripts/**

# Tests
**/*.map
**/*.test.*
**/__tests__/**
**/__mocks__/**
**/*.spec.*
test/
tests/

# Node modules cleanup
node_modules/.bin/**
node_modules/**/.git/**
node_modules/**/.github/**
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/*.md
!node_modules/**/README.md
node_modules/**/*.ts
!node_modules/**/*.d.ts
node_modules/**/.*
node_modules/**/CHANGELOG*
node_modules/**/HISTORY*

# Keep these
!out/**
!package.json
!README.md
!LICENSE
