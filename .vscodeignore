# Exclude source and dev files from the VSIX package

# Workspace data
.cappy/
.cappy/**
.agents/
.agents/**
.cursor/
.cursor/**
mcps/
mcps/**
agent-transcripts/
agent-transcripts/**

# Dev folders
.vscode/
.git/
.gitignore
.github/
old/
coverage/
dist/
tmp/
*.tmp

# Source code (compiled output is in out/)
src/**
!src/assets/**

# Config files
tsconfig*.json
tsconfig*.tsbuildinfo
vitest.config.ts
eslint.config.js
.eslintignore
.eslintrc*
.prettierrc*
*.log
.env
.env.local
.env.*
!.env.example
*.plan.md

# Scripts
scripts/**
install.ps1
install.sh

# Tests
**/*.map
**/*.test.*
**/__tests__/**
**/__mocks__/**
**/*.spec.*
test/
tests/

# Node modules cleanup
node_modules/.bin/**
node_modules/**/.git/**
node_modules/**/.github/**
node_modules/**/.vscode/**
node_modules/**/docs/**
node_modules/**/test/**
node_modules/**/tests/**
node_modules/**/example/**
node_modules/**/examples/**
node_modules/**/benchmark/**
node_modules/**/benchmarks/**
node_modules/**/*.md
!node_modules/**/README.md
node_modules/**/*.ts
!node_modules/**/*.d.ts
node_modules/**/.*
node_modules/**/CHANGELOG*
node_modules/**/HISTORY*

# Keep these
!out/**
!package.json
!README.md
!LICENSE
!LICENSE.*
