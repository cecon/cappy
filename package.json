{
  "name": "cappy",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "extension",
    "webview",
    "cli-mock"
  ],
  "scripts": {
    "dev": "concurrently -k -n webview,cli-mock -c blue,green \"npm run dev -w webview\" \"npm run dev -w cli-mock\"",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
